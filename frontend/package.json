  "scripts": {
    "build": "vite build",
    "build:ci": "vite build -m development",
    "check": "eslint src",
    "check:fix": "eslint src --fix",
    "check:ts": "tsc --noEmit --incremental false",
    "check:fmt": "prettier -c .",
    "coverage": "vitest run --coverage",
    "format": "prettier -w .",
    "pwa-assets:generate": "pwa-assets-generator --preset minimal-2023 public/images/logo128.png",
    "prepare": "cd .. && husky frontend/.husky",
    "preview": "vite preview",
    "start": "vite",
    "test": "vitest",
    "test:ui": "vitest --ui"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "overrides": {
    "serialize-javascript": "^7.0.4",
    "follow-redirects": "^1.16.0",
    "esbuild": "^0.28.1",
    "@babel/core": "^7.29.7",
    "eslint-plugin-react-hooks": {
      "eslint": "$eslint"
    }
  }
